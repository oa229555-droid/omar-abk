{
  "expo": {
    "name": "MESHBOOK",
    "slug": "meshbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.meshbook.app",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "يحتاج التطبيق للبلوتوث للاتصال بالأجهزة القريبة بدون إنترنت",
        "NSBluetoothPeripheralUsageDescription": "يحتاج التطبيق للبلوتوث لمشاركة المنشورات مع الأجهزة القريبة",
        "NSLocationWhenInUseUsageDescription": "يحتاج التطبيق للموقع لاكتشاف الأجهزة القريبة منك"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.meshbook.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_ADVERTISE",
        "NEARBY_WIFI_DEVICES"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}
